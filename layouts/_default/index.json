{{- $index := slice -}}
{{- range site.RegularPages -}}
    {{/* This version removes the 'if eq .Type' filters to include everything */}}
    {{- $entry := dict "title" .Title "permalink" .RelPermalink "summary" (.Summary | plainify | truncate 1000) "date" (.Date.Format "2006-01-02") "tags" (.Params.tags | default slice) "content" (.Plain | truncate 1000) -}}
    {{- $index = $index | append $entry -}}
{{- end -}}
{{- $index | jsonify -}}